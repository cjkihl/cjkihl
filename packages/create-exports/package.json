{
  "name": "@cjkihl/create-exports",
  "version": "1.0.12",
  "description": "Tool to generate package exports configuration for TypeScript packages",
  "keywords": [
    "typescript",
    "exports",
    "package",
    "configuration",
    "build-tool"
  ],
  "homepage": "https://github.com/cjkihl/cjkihl#readme",
  "bugs": {
    "url": "https://github.com/cjkihl/cjkihl/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cjkihl/cjkihl.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/cjkihl"
  },
  "license": "MIT",
  "author": "@cjkihl",
  "type": "module",
  "exports": {
    ".": {
      "default": "./dist/output/index.pub.js",
      "types": "./dist/types/index.pub.d.ts"
    }
  },
  "bin": {
    "create-exports": "./dist/output/create-exports.bin.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsgo && bun ../create-exports/create-exports.bin.ts",
    "test": "bun test",
    "type-check": "tsgo --noEmit"
  },
  "dependencies": {
    "fast-glob": "^3.3.3",
    "get-tsconfig": "^4.13.7",
    "sort-package-json": "^3.6.1",
    "type-fest": "^5.4.4"
  },
  "devDependencies": {
    "@types/bun": "1.3.9",
    "@types/node": "^24.10.13"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
