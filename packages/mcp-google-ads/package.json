    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cjkihl/tsconfig": "workspace:*",
    "@cjkihl/with-env": "^1.0.15",
    "@types/node": "^20.19.33",
    "bun-types": "1.3.9"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
