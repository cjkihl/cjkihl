{
  "name": "@cjkihl/mcp-google-ads",
  "version": "0.1.2",
  "private": true,
  "description": "MCP Server for Google Ads API",
  "type": "module",
  "exports": {},
  "bin": {
    "index": "./dist/output/src/index.bin.js"
  },
  "scripts": {
    "build": "tsgo && bun ../create-exports/create-exports.bin.ts",
